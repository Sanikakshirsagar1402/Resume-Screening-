{
  "name": "resume-screening-system",
  "version": "1.0.0",
  "description": "AI-powered Resume Screening System",
  "main": "server/server.js",
  "scripts": {
    "install-all": "npm install && cd client/my-project && npm install && cd ../../server && npm install",
    "build": "cd client/my-project && npm run build",
    "start": "node server/server.js",
    "server": "cd server && npm start",
    "client": "cd client/my-project && npm run dev",
    "render-postbuild": "pip install --no-cache-dir -r server/ml/requirements.txt"
  },
  "dependencies": {
    "react-hot-toast": "^2.6.0"
  }
}